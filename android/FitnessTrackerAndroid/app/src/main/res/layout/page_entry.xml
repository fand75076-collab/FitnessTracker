<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_horizontal"
        android:paddingEnd="@dimen/page_horizontal"
        android:paddingTop="@dimen/page_top"
        android:paddingBottom="@dimen/page_bottom">

        <!-- Section title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="记录单组训练"
            style="@style/Text.SectionTitle" />

        <!-- Timestamp -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="完成时间"
            style="@style/Text.MetricLabel"
            android:layout_marginTop="@dimen/space_md" />

        <EditText
            android:id="@+id/input_timestamp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginTop="@dimen/space_xs"
            android:hint="yyyy-MM-dd HH:mm"
            android:inputType="datetime"
            style="@style/Widget.App.Input" />

        <!-- Exercise name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="动作名称"
            style="@style/Text.MetricLabel"
            android:layout_marginTop="@dimen/space_lg" />

        <AutoCompleteTextView
            android:id="@+id/input_exercise"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginTop="@dimen/space_xs"
            android:hint="输入或选择动作"
            android:completionThreshold="1"
            style="@style/Widget.App.Input" />

        <!-- Body part -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="部位"
            style="@style/Text.MetricLabel"
            android:layout_marginTop="@dimen/space_lg" />

        <Spinner
            android:id="@+id/spinner_body_part"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginTop="@dimen/space_xs"
            android:background="@drawable/bg_input"
            android:paddingStart="@dimen/input_padding_h"
            android:paddingEnd="@dimen/input_padding_h" />

        <!-- Weight / Reps / Set row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/space_lg">

            <!-- Weight -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/space_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重量"
                    style="@style/Text.MetricLabel" />

                <EditText
                    android:id="@+id/input_weight"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/space_xs"
                    android:hint="kg"
                    android:inputType="numberDecimal"
                    style="@style/Widget.App.Input" />
            </LinearLayout>

            <!-- Reps -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/space_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次数"
                    style="@style/Text.MetricLabel" />

                <EditText
                    android:id="@+id/input_reps"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/space_xs"
                    android:hint="次"
                    android:inputType="number"
                    style="@style/Widget.App.Input" />
            </LinearLayout>

            <!-- Set number -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="组"
                    style="@style/Text.MetricLabel" />

                <EditText
                    android:id="@+id/input_set"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/space_xs"
                    android:hint="#"
                    android:inputType="number"
                    style="@style/Widget.App.Input" />
            </LinearLayout>
        </LinearLayout>

        <!-- Notes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="备注"
            style="@style/Text.MetricLabel"
            android:layout_marginTop="@dimen/space_lg" />

        <EditText
            android:id="@+id/input_notes"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginTop="@dimen/space_xs"
            android:hint="可选，例如状态、RPE"
            android:inputType="text"
            style="@style/Widget.App.Input" />

        <!-- Save button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_xl"
            android:text="保存这一组"
            style="@style/Widget.App.Button.Primary" />

    </LinearLayout>
</ScrollView>
